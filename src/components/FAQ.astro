---
const faqs = [
  {
    q: "How much does a kitchen or bath remodel typically cost?",
    a: "Honest answer: it depends on scope and finishes. Most of our kitchens land between $35k and $90k, and bathrooms run $18k to $45k. After your free in-home consult we send a written, line-item quote — no obligation.",
  },
  {
    q: "Are you licensed and insured?",
    a: "Yes. We're a registered NJ Home Improvement Contractor (HIC #13VH00000000), fully insured, and bonded. We're happy to email proof of all three before we start.",
  },
  {
    q: "What's your timeline like?",
    a: "Most kitchens take 4–8 weeks once permits are pulled. Full-house renovations run 3–6 months. We'll walk you through a realistic schedule the day we quote — and we update it weekly.",
  },
  {
    q: "Do you handle permits?",
    a: "Always. We pull every permit ourselves and meet the inspector on site. You don't have to chase the township.",
  },
  {
    q: "Where do you work?",
    a: "Bergen, Passaic, Hudson, Essex, and Morris counties. If you're outside that radius, give us a call — for the right project we'll travel a little farther.",
  },
];
---

<section class="bg-white py-20" id="faq">
  <div class="mx-auto max-w-[820px] px-6">
    <div class="mb-10 text-center">
      <p
        class="mb-3 text-xs font-medium uppercase tracking-[0.35rem] text-gray"
      >
        Common Questions
      </p>
      <h2
        class="text-[clamp(28px,4.2vw,38px)] font-bold leading-tight tracking-[-0.05rem] text-my-black"
      >
        Things homeowners ask <span class="text-main">first</span>.
      </h2>
    </div>

    <div>
      {
        faqs.map(({ q, a }, i) => (
          <details
            class="group border-t border-my-black/10 [&:last-child]:border-b"
            open={i === 0}
          >
            <summary
              class="flex cursor-pointer list-none items-center justify-between gap-4 py-6 text-[17px] font-semibold text-my-black [&::-webkit-details-marker]:hidden"
            >
              <span>{q}</span>
              <span
                class="material-symbols-outlined text-[24px] text-main transition-transform duration-200 group-open:rotate-45"
              >
                add
              </span>
            </summary>
            <div class="pb-6 text-[15px] leading-relaxed text-wolf-gray">
              {a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
