---
import CTAButton from "./CallToActionBtn.astro";
---

<div
  class="inner-hero-content clip-path z-[100] flex items-center bg-light-gray px-5 py-10 sm:absolute sm:h-full sm:w-full"
>
  <section class="ml-0 sm:max-w-[400px] min-[1200px]:max-w-[450px]">
    <div
      class="mb-5 text-left text-xs font-medium uppercase tracking-[5.25px] text-gray sm:text-sm min-[1200px]:mb-10"
    >
      North Jersey Home Renovation
    </div>
    <h1
      class="mb-3 max-w-[320px] text-[33px] font-bold leading-tight tracking-[-0.75px] text-black sm:max-w-none sm:text-[39px] min-[1200px]:text-5xl"
    >
      Dreaming of a new <span class="typed text-main"></span>?
    </h1>
    <p class="mb-6 text-2xl font-semibold text-my-black min-[1200px]:mb-10">
      Let's Build It.
    </p>
    <p
      class="mb-5 text-base text-wolf-gray min-[1200px]:mb-10 min-[1200px]:text-lg"
    >
      We'll help you bring your vision to life and transform your home into a
      space that's functional, enjoyable, and inspiring.
    </p>
    <CTAButton
      content="Start Your Project"
      icon="arrow_right_alt"
      color="bg-dark-metallic"
      href="#book"
    />
  </section>
</div>
