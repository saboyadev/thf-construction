---
import FooterLayout from "../layouts/FooterLayout.astro";

const phone = "+12016860089";
const phoneDisplay = "(201) 686-0089";
const email = "wider@thfconstructionnj.com";
const mapsUrl = "https://www.google.com/maps?q=Garfield,+NJ+07026";
const year = new Date().getFullYear();
---

<FooterLayout>
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-[1200px] px-6 pb-8 pt-16">
    <div class="grid gap-12 md:grid-cols-[1.2fr_2fr]">
      <!-- Brand -->
      <div>
        <img
          src="/src/images/Logo-White.png"
          alt="THF Construction"
          class="mb-3.5 h-auto w-40"
        />
        <p class="mb-4 text-sm italic leading-relaxed text-wolf-gray">
          "Trust, Honesty, and Family at our core."
        </p>
        <p class="mb-4 text-[13px] leading-relaxed text-gray">
          THF Construction LLC<br />
          Garfield, NJ 07026<br />
          NJ HIC #13VH00000000<br />
          Insured &amp; bonded
        </p>
        <div class="flex gap-3.5">
          <a href="#" aria-label="Facebook" class="text-metallic hover:text-egg-white">
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
              ></path>
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="text-metallic hover:text-egg-white">
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2c2.7 0 3 0 4.1.1 1 0 1.7.2 2.4.5.7.3 1.2.6 1.8 1.2.6.6.9 1.1 1.2 1.8.3.7.4 1.4.5 2.4.1 1.1.1 1.4.1 4.1s0 3-.1 4.1c0 1-.2 1.7-.5 2.4-.3.7-.6 1.2-1.2 1.8-.6.6-1.1.9-1.8 1.2-.7.3-1.4.4-2.4.5-1.1.1-1.4.1-4.1.1s-3 0-4.1-.1c-1 0-1.7-.2-2.4-.5-.7-.3-1.2-.6-1.8-1.2-.6-.6-.9-1.1-1.2-1.8-.3-.7-.4-1.4-.5-2.4C2 15 2 14.7 2 12s0-3 .1-4.1c0-1 .2-1.7.5-2.4C2.9 4.8 3.2 4.3 3.8 3.7c.6-.6 1.1-.9 1.8-1.2.7-.3 1.4-.4 2.4-.5C9.1 2 9.4 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm6.4-.5a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4zM12 9a3 3 0 110 6 3 3 0 010-6z"
              ></path>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="text-metallic hover:text-egg-white">
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M19.8 5.4c.9.2 1.6.9 1.8 1.8C22 8.7 22 12 22 12s0 3.3-.4 4.8a2.5 2.5 0 01-1.8 1.8c-1.6.4-7.8.4-7.8.4s-6.3 0-7.8-.4a2.5 2.5 0 01-1.8-1.8C2 15.3 2 12 2 12s0-3.3.4-4.8a2.5 2.5 0 011.8-1.8C5.7 5 12 5 12 5s6.3 0 7.8.4ZM15.2 12 10 15V9l5.2 3Z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link cols -->
      <div class="grid gap-8 sm:grid-cols-3">
        <div>
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-wider text-egg-white"
          >
            Interior
          </h3>
          <ul class="space-y-2.5">
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Kitchens</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Bathrooms</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Basements</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Attics</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Full renovations</a></li>
          </ul>
        </div>
        <div>
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-wider text-egg-white"
          >
            Exterior
          </h3>
          <ul class="space-y-2.5">
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Stucco &amp; siding</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Decks</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Pavers &amp; patios</a></li>
            <li><a href="#services" class="text-sm text-gray hover:text-egg-white">Stone &amp; hardscape</a></li>
          </ul>
        </div>
        <div>
          <h3
            class="mb-4 text-sm font-semibold uppercase tracking-wider text-egg-white"
          >
            Contact
          </h3>
          <ul class="space-y-2.5">
            <li><a href={`tel:${phone}`} class="text-sm text-gray hover:text-egg-white">{phoneDisplay}</a></li>
            <li><a href={`mailto:${email}`} class="text-sm text-gray hover:text-egg-white">{email}</a></li>
            <li><a href={mapsUrl} target="_blank" rel="noopener" class="text-sm text-gray hover:text-egg-white">Garfield, NJ 07026</a></li>
            <li><a href="#book" class="text-sm text-gray hover:text-egg-white">Book consultation</a></li>
            <li><a href="#faq" class="text-sm text-gray hover:text-egg-white">FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <div
    class="mx-auto flex max-w-[1200px] flex-wrap justify-between gap-2 border-t border-egg-white/10 px-6 py-5 text-center text-xs text-metallic"
  >
    <p class="m-0">© {year} THF Construction LLC. All rights reserved.</p>
    <p class="m-0">
      Garfield, NJ · Serving Bergen, Passaic, Hudson, Essex &amp; Morris counties
    </p>
  </div>
</FooterLayout>
